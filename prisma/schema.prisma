generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  PAID
}

model Appointment {
  id        String            @id @default(cuid())
  date      DateTime
  time      String
  telephone String
  paymentId String?
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("appointments")
}
